# Invoice MVP 환경 변수 예시
# 이 파일을 복사하여 .env.local 파일을 생성하세요
# cp .env.example .env.local

# ============================================================
# Notion API
# ============================================================
# Notion Integration Token (My Integrations에서 발급)
# https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion 견적서 데이터베이스 ID
# 데이터베이스 URL에서 추출: notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Supabase
# ============================================================
# Supabase 프로젝트 URL
# Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase 익명 키 (공개 가능)
# Project Settings > API > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase 서비스 롤 키 (서버 사이드 전용, 절대 공개하지 마세요)
# Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# 앱 설정
# ============================================================
# 프로덕션 도메인 (공개 링크 생성에 사용)
NEXT_PUBLIC_APP_URL=http://localhost:3000
